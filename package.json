{
	"name": "obsidian-vilot",
	"version": "0.1.0",
	"description": "Vilot — an agentic AI assistant for Obsidian that understands your vault",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run"
	},
	"keywords": [
		"obsidian",
		"ai",
		"agent",
		"copilot-sdk",
		"vault"
	],
	"author": "Ali Soliman",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitepress": "^1.6.4",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"@github/copilot-sdk": "^0.1.25"
	}
}
